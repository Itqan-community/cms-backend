{
  "name": "docs-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "DOCS_ENV=localhost node scripts/set-api-base-url.mjs && docusaurus clean-api-docs public && docusaurus gen-api-docs public && DOCS_ENV=localhost docusaurus start",
    "start:ar": "DOCS_ENV=localhost node scripts/set-api-base-url.mjs && docusaurus clean-api-docs public && docusaurus gen-api-docs public && DOCS_ENV=localhost docusaurus start --locale ar",
    "preview": "docusaurus build && docusaurus serve",
    "prebuild": "node scripts/set-api-base-url.mjs && docusaurus clean-api-docs public && docusaurus gen-api-docs public",
    "build": "docusaurus build",
    "build:staging": "DOCS_ENV=staging npm run build",
    "build:prod": "DOCS_ENV=production npm run build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "docusaurus-plugin-openapi-docs": "^5.0.2",
    "docusaurus-theme-openapi-docs": "^5.0.2",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
