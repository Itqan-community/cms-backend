/node_modules

# Production
/build

# Generated files
.docusaurus
.cache-loader
# OpenAPI reference pages are generated by `docusaurus gen-api-docs public`.
# Ignore everything in the dir EXCEPT the hand-written index.md overview page,
# which sidebars.ts links to (`reference/api/index`) and must exist at build time.
docs/reference/api/*
!docs/reference/api/index.md

